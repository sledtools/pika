{
  "name": "pikachat-openclaw",
  "version": "1.1.1",
  "description": "OpenClaw Pikachat channel plugin (daemon protocol client)",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "bech32": "^2.0.0"
  },
  "devDependencies": {
    "openclaw": "^2026.2.26",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.26"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "pikachat-openclaw",
      "label": "Pikachat",
      "selectionLabel": "Pikachat (Rust)",
      "docsPath": "/channels/pikachat-openclaw",
      "docsLabel": "pikachat-openclaw",
      "blurb": "MLS E2EE groups over Nostr (daemon protocol).",
      "order": 56,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "pikachat-openclaw",
      "localPath": "extensions/pikachat-openclaw",
      "defaultChoice": "path"
    }
  }
}
