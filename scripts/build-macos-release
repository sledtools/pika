#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION_FILE="$ROOT/VERSION"
ICON_SOURCE="$ROOT/ios/Sources/Assets.xcassets/AppIcon.appiconset/icon_1024x1024.png"
INFO_PLIST_TEMPLATE="$ROOT/scripts/build-macos-release.Info.plist.template"

APP_NAME="Pika.app"
APP_EXECUTABLE_NAME="Pika"
APP_DISPLAY_NAME="Pika"
BUNDLE_ID="org.pikachat.pika"
DESKTOP_PACKAGE="pika-desktop"
DESKTOP_BIN_NAME="pika-desktop"
RUST_PROFILE="release"
MACOS_TARGETS=(aarch64-apple-darwin x86_64-apple-darwin)

RELEASE_DIR="$ROOT/target/release/macos"
APP_DIR="$RELEASE_DIR/$APP_NAME"
APP_CONTENTS_DIR="$APP_DIR/Contents"
APP_MACOS_DIR="$APP_CONTENTS_DIR/MacOS"
APP_RESOURCES_DIR="$APP_CONTENTS_DIR/Resources"
APP_EXECUTABLE="$APP_MACOS_DIR/$APP_EXECUTABLE_NAME"
ICON_FILE="$APP_RESOURCES_DIR/pika.icns"

DIST_DIR="$ROOT/dist"

declare -a CLEANUP_DIRS=()
declare -a CARGO_CMD=(cargo)

RUSTC_PATH=""
bundle_version=""
deployment_target=""
git_revision=""
toolchain=""
version=""

# shellcheck source=scripts/lib/mobile-build.sh
source "$ROOT/scripts/lib/mobile-build.sh"

usage() {
  cat <<'EOF'
usage: ./scripts/build-macos-release

Builds the universal macOS Pika.app bundle and packages it as a DMG in dist/.

Environment overrides:
  MACOSX_DEPLOYMENT_TARGET   Minimum supported macOS version (default: 13.0)
  PIKA_MACOS_RUST_TOOLCHAIN  Rust toolchain for the universal cargo builds (default: stable)
  PIKA_ALLOW_NIX_STORE_LINKS Allow /nix/store-linked binaries in the packaged app when set to 1
EOF
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: missing command: $1" >&2
    exit 1
  fi
}

require_file() {
  local path="$1"
  if [ ! -f "$path" ]; then
    echo "error: missing required file: $path" >&2
    exit 1
  fi
}

register_cleanup_dir() {
  CLEANUP_DIRS+=("$1")
}

cleanup() {
  local path
  for path in "${CLEANUP_DIRS[@]:-}"; do
    rm -rf "$path"
  done
}
trap cleanup EXIT

sed_escape_replacement() {
  printf '%s' "$1" | sed -e 's/[&|\\]/\\&/g'
}

ensure_prerequisites() {
  local cmd
  for cmd in cargo lipo hdiutil sips iconutil otool git; do
    need_cmd "$cmd"
  done

  require_file "$VERSION_FILE"
  require_file "$ICON_SOURCE"
  require_file "$INFO_PLIST_TEMPLATE"
}

load_release_metadata() {
  version="$(tr -d '[:space:]' <"$VERSION_FILE")"
  if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "error: VERSION must be x.y.z (got: $version)" >&2
    exit 1
  fi

  deployment_target="${MACOSX_DEPLOYMENT_TARGET:-13.0}"
  export MACOSX_DEPLOYMENT_TARGET="$deployment_target"

  git_revision="$(git -C "$ROOT" rev-parse --short HEAD)"
  bundle_version="$version"
}

prepare_release_dirs() {
  mkdir -p "$DIST_DIR"
  rm -rf "$RELEASE_DIR"
  mkdir -p "$APP_MACOS_DIR" "$APP_RESOURCES_DIR"
}

configure_rust_toolchain() {
  toolchain="${PIKA_MACOS_RUST_TOOLCHAIN:-stable}"
  CARGO_CMD=(cargo)
  RUSTC_PATH=""

  if command -v rustup >/dev/null 2>&1; then
    rustup toolchain install "$toolchain" --profile minimal >/dev/null 2>&1 || true
    rustup target add --toolchain "$toolchain" "${MACOS_TARGETS[@]}"
    CARGO_CMD=(rustup run "$toolchain" cargo)
    RUSTC_PATH="$(rustup which --toolchain "$toolchain" rustc)"
  fi
}

build_desktop_target() {
  local target="${1:?target is required}"
  local -a cmd=("${CARGO_CMD[@]}" build -p "$DESKTOP_PACKAGE" --release --target "$target")

  if [ -n "$RUSTC_PATH" ]; then
    RUSTC="$RUSTC_PATH" "${cmd[@]}"
    return 0
  fi

  "${cmd[@]}"
}

desktop_target_binary_path() {
  local target="${1:?target is required}"
  (
    cd "$ROOT"
    find_target_binary "$DESKTOP_BIN_NAME" "$target" "$RUST_PROFILE"
  )
}

build_universal_app_binary() {
  local arm_binary
  local x86_binary
  local target

  echo "Building pika-desktop (arm64 + x86_64)..."
  for target in "${MACOS_TARGETS[@]}"; do
    build_desktop_target "$target"
  done

  arm_binary="$(desktop_target_binary_path aarch64-apple-darwin)"
  x86_binary="$(desktop_target_binary_path x86_64-apple-darwin)"

  lipo -create "$arm_binary" "$x86_binary" -output "$APP_EXECUTABLE"
  chmod 755 "$APP_EXECUTABLE"
}

build_app_icon() {
  local icon_tmp
  local iconset_dir
  local size
  local double_size

  icon_tmp="$(mktemp -d)"
  register_cleanup_dir "$icon_tmp"
  iconset_dir="$icon_tmp/pika.iconset"
  mkdir -p "$iconset_dir"

  for size in 16 32 128 256 512; do
    sips -z "$size" "$size" "$ICON_SOURCE" --out "$iconset_dir/icon_${size}x${size}.png" >/dev/null
    double_size=$((size * 2))
    sips -z "$double_size" "$double_size" "$ICON_SOURCE" --out "$iconset_dir/icon_${size}x${size}@2x.png" >/dev/null
  done

  iconutil -c icns "$iconset_dir" -o "$ICON_FILE"
}

render_info_plist() {
  local executable_name_esc
  local bundle_id_esc
  local version_esc
  local bundle_version_esc
  local git_revision_esc
  local deployment_target_esc

  executable_name_esc="$(sed_escape_replacement "$APP_EXECUTABLE_NAME")"
  bundle_id_esc="$(sed_escape_replacement "$BUNDLE_ID")"
  version_esc="$(sed_escape_replacement "$version")"
  bundle_version_esc="$(sed_escape_replacement "$bundle_version")"
  git_revision_esc="$(sed_escape_replacement "$git_revision")"
  deployment_target_esc="$(sed_escape_replacement "$deployment_target")"

  sed \
    -e "s|__APP_EXECUTABLE_NAME__|$executable_name_esc|g" \
    -e "s|__BUNDLE_ID__|$bundle_id_esc|g" \
    -e "s|__VERSION__|$version_esc|g" \
    -e "s|__BUNDLE_VERSION__|$bundle_version_esc|g" \
    -e "s|__GIT_REVISION__|$git_revision_esc|g" \
    -e "s|__DEPLOYMENT_TARGET__|$deployment_target_esc|g" \
    "$INFO_PLIST_TEMPLATE" >"$APP_CONTENTS_DIR/Info.plist"
}

assert_no_nix_store_links() {
  if [ "${PIKA_ALLOW_NIX_STORE_LINKS:-0}" != "1" ] && otool -L "$APP_EXECUTABLE" | grep -q '/nix/store/'; then
    echo "error: app binary links against /nix/store paths; build outside nix shell for release" >&2
    otool -L "$APP_EXECUTABLE" >&2
    exit 1
  fi
}

package_dmg() {
  local dmg_path

  rm -f "$RELEASE_DIR/Applications"
  ln -s /Applications "$RELEASE_DIR/Applications"

  dmg_path="$DIST_DIR/pika-${version}-macos-universal.dmg"
  rm -f "$dmg_path"
  hdiutil create "$dmg_path" -volname "$APP_DISPLAY_NAME" -fs HFS+ -srcfolder "$RELEASE_DIR" -ov -format UDZO >/dev/null

  echo "ok: built $dmg_path"
}

main() {
  if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    usage
    return 0
  fi
  if [ "$#" -ne 0 ]; then
    usage >&2
    return 2
  fi

  cd "$ROOT"
  ensure_prerequisites
  load_release_metadata
  prepare_release_dirs
  configure_rust_toolchain
  build_universal_app_binary
  build_app_icon
  render_info_plist
  assert_no_nix_store_links
  package_dmg
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
