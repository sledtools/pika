#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"

files=(
  "$ROOT/secrets/android-keystore.jks.sops"
  "$ROOT/secrets/android-signing.sops.yaml"
  "$ROOT/secrets/zapstore-signing.sops.yaml"
  "$ROOT/secrets/pikaci-apple.sops.yaml"
)

sops_secret_need_cmd sops
sops_secret_prepare_env

checked=0
for file in "${files[@]}"; do
  if [ ! -f "$file" ]; then
    continue
  fi

  echo "==> checking $file"
  sops filestatus "$file" >/dev/null
  case "$file" in
    *.sops.yaml)
      sops decrypt "$file" >/dev/null
      ;;
    *.sops)
      sops decrypt --input-type binary --output-type binary "$file" >/dev/null
      ;;
    *)
      echo "error: unsupported repo secret file: $file" >&2
      exit 1
      ;;
  esac
  checked=1
done

if [ "$checked" -eq 0 ]; then
  echo "note: no repo sops files found under $ROOT/secrets"
fi
