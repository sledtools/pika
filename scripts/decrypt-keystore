#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOPS_KEYSTORE="$ROOT/secrets/android-keystore.jks.sops"
AGE_KEYSTORE="$ROOT/android/pika-release.jks.age"
OUTPUT_KEYSTORE="$ROOT/android/pika-release.jks"
# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

# shellcheck disable=SC1091
source "$ROOT/tools/lib/dotenv.sh"
load_dotenv_no_override "$ROOT"

if [ -f "$SOPS_KEYSTORE" ]; then
  sops_secret_decrypt_binary "$SOPS_KEYSTORE" "$OUTPUT_KEYSTORE"
else
  release_secret_require_file "$AGE_KEYSTORE" "encrypted keystore" "create it once and commit android/pika-release.jks.age or migrate to secrets/android-keystore.jks.sops"
  release_secret_decrypt_to_file "$AGE_KEYSTORE" "$OUTPUT_KEYSTORE"
fi

chmod 600 "$OUTPUT_KEYSTORE"
echo "ok: decrypted keystore -> $OUTPUT_KEYSTORE"
