#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENCRYPTED_KEYSTORE="$ROOT/android/pika-release.jks.age"
OUTPUT_KEYSTORE="$ROOT/android/pika-release.jks"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

# shellcheck disable=SC1091
source "$ROOT/tools/lib/dotenv.sh"
load_dotenv_no_override "$ROOT"

release_secret_require_file "$ENCRYPTED_KEYSTORE" "encrypted keystore" "create it once and commit android/pika-release.jks.age"

release_secret_decrypt_to_file "$ENCRYPTED_KEYSTORE" "$OUTPUT_KEYSTORE"

chmod 600 "$OUTPUT_KEYSTORE"
echo "ok: decrypted keystore -> $OUTPUT_KEYSTORE"
