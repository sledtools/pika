#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUTPUT_ENCRYPTED="$ROOT/secrets/pikaci-apple.env.age"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

usage() {
  cat <<'USAGE'
usage: ./scripts/encrypt-pikaci-apple-secrets

Encrypts `secrets/pikaci-apple.env.age` with:
  - YubiKey primary recipient
  - YubiKey backup recipient
  - CI recipient (from PIKA_CI_AGE_RECIPIENT or repo defaults)

Required inputs:
  - `PIKACI_APPLE_TAILSCALE_AUTHKEY`
  - one of:
    - `PIKACI_APPLE_SSH_KEY`
    - `PIKACI_APPLE_SSH_KEY_FILE`

Interactive fallback:
  - prompts for the Tailscale auth key
  - prompts for a private key file path

Environment overrides:
  PIKACI_APPLE_TAILSCALE_AUTHKEY
  PIKACI_APPLE_SSH_KEY
  PIKACI_APPLE_SSH_KEY_FILE
  PIKA_CI_AGE_RECIPIENT
  PIKA_YUBIKEY_PRIMARY_RECIPIENT
  PIKA_YUBIKEY_BACKUP_RECIPIENT
USAGE
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi
if [ "$#" -ne 0 ]; then
  usage >&2
  exit 2
fi

release_secret_load_recipients "$ROOT"
release_secret_validate_age_recipient "$RELEASE_SECRET_CI_RECIPIENT" "CI recipient"

tailscale_authkey="${PIKACI_APPLE_TAILSCALE_AUTHKEY:-}"
ssh_key="${PIKACI_APPLE_SSH_KEY:-}"
ssh_key_file="${PIKACI_APPLE_SSH_KEY_FILE:-}"

if [ -z "$tailscale_authkey" ]; then
  if [ ! -t 0 ]; then
    echo "error: set PIKACI_APPLE_TAILSCALE_AUTHKEY when running non-interactively" >&2
    exit 1
  fi
  read -r -s -p "Enter Apple mini Tailscale auth key: " tailscale_authkey
  printf '\n'
fi

if [ -z "$ssh_key" ] && [ -n "$ssh_key_file" ]; then
  if [ ! -f "$ssh_key_file" ]; then
    echo "error: missing SSH private key file: $ssh_key_file" >&2
    exit 1
  fi
  ssh_key="$(cat "$ssh_key_file")"
fi

if [ -z "$ssh_key" ]; then
  if [ ! -t 0 ]; then
    echo "error: set PIKACI_APPLE_SSH_KEY or PIKACI_APPLE_SSH_KEY_FILE when running non-interactively" >&2
    exit 1
  fi
  read -r -p "Path to Apple mini SSH private key: " ssh_key_file
  if [ ! -f "$ssh_key_file" ]; then
    echo "error: missing SSH private key file: $ssh_key_file" >&2
    exit 1
  fi
  ssh_key="$(cat "$ssh_key_file")"
fi

if [ -z "$tailscale_authkey" ]; then
  echo "error: missing Apple mini Tailscale auth key" >&2
  exit 1
fi
if [ -z "$ssh_key" ]; then
  echo "error: missing Apple mini SSH private key" >&2
  exit 1
fi

mkdir -p "$ROOT/secrets"
umask 077

tmp_plaintext="$(mktemp "$ROOT/secrets/.pikaci-apple.XXXXXX.env")"
cleanup() {
  rm -f "$tmp_plaintext"
}
trap cleanup EXIT INT TERM

{
  printf 'PIKACI_APPLE_TAILSCALE_AUTHKEY=%q\n' "$tailscale_authkey"
  printf 'PIKACI_APPLE_SSH_KEY=%q\n' "$ssh_key"
} > "$tmp_plaintext"

release_secret_encrypt_file "$tmp_plaintext" "$OUTPUT_ENCRYPTED"

unset tailscale_authkey
unset ssh_key
unset ssh_key_file

echo "ok: wrote $OUTPUT_ENCRYPTED"
echo "ok: recipients:"
echo "  - $RELEASE_SECRET_YUBIKEY_PRIMARY"
echo "  - $RELEASE_SECRET_YUBIKEY_BACKUP"
echo "  - $RELEASE_SECRET_CI_RECIPIENT (CI)"
