#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUTPUT_ENCRYPTED="$ROOT/secrets/zapstore-signing.sops.yaml"
# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

usage() {
  cat <<'USAGE'
usage: ./scripts/encrypt-zapstore-signing

Encrypts `secrets/zapstore-signing.sops.yaml` with:
  - YubiKey primary recipient
  - YubiKey backup recipient
  - CI recipient (from PIKA_CI_AGE_RECIPIENT or repo defaults)

Input:
  - `PIKA_ZAPSTORE_SIGN_WITH` (recommended)
  - or interactive prompt

Environment overrides:
  PIKA_ZAPSTORE_SIGN_WITH
  PIKA_CI_AGE_RECIPIENT
  PIKA_YUBIKEY_PRIMARY_RECIPIENT
  PIKA_YUBIKEY_BACKUP_RECIPIENT
USAGE
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi
if [ "$#" -ne 0 ]; then
  usage >&2
  exit 2
fi

release_secret_load_recipients "$ROOT"
release_secret_validate_age_recipient "$RELEASE_SECRET_CI_RECIPIENT" "CI recipient"
sops_secret_need_cmd sops

sign_with="${PIKA_ZAPSTORE_SIGN_WITH:-}"
if [ -z "$sign_with" ]; then
  if [ ! -t 0 ]; then
    echo "error: set PIKA_ZAPSTORE_SIGN_WITH when running non-interactively" >&2
    exit 1
  fi
  read -r -s -p "Enter Zapstore SIGN_WITH (nsec or bunker URL): " sign_with
  printf '\n'
fi

if [ -z "$sign_with" ]; then
  echo "error: missing Zapstore SIGN_WITH value" >&2
  exit 1
fi

mkdir -p "$ROOT/secrets"
umask 077

tmp_plaintext="$(mktemp "$ROOT/secrets/.zapstore-signing.XXXXXX.yaml")"
cleanup() {
  rm -f "$tmp_plaintext"
}
trap cleanup EXIT INT TERM

sops_secret_write_yaml_file "$tmp_plaintext" "ZAPSTORE_SIGN_WITH" "$sign_with"

recipients=(
  "$RELEASE_SECRET_YUBIKEY_PRIMARY"
  "$RELEASE_SECRET_YUBIKEY_BACKUP"
  "$RELEASE_SECRET_CI_RECIPIENT"
)
recipients_csv="$(IFS=,; printf '%s' "${recipients[*]}")"
sops_secret_encrypt_yaml_file "$tmp_plaintext" "$OUTPUT_ENCRYPTED" "$recipients_csv"

unset sign_with

echo "ok: wrote $OUTPUT_ENCRYPTED"
echo "ok: recipients:"
echo "  - $RELEASE_SECRET_YUBIKEY_PRIMARY"
echo "  - $RELEASE_SECRET_YUBIKEY_BACKUP"
echo "  - $RELEASE_SECRET_CI_RECIPIENT (CI)"
