#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

KEYSTORE_ENCRYPTED="$ROOT/secrets/android-keystore.jks.sops"
PASSWORD_ENCRYPTED="$ROOT/secrets/android-signing.sops.yaml"
ZAPSTORE_SIGNING_ENCRYPTED="$ROOT/secrets/zapstore-signing.sops.yaml"
KEYSTORE_PLAINTEXT="$ROOT/android/pika-release.jks"
KEYSTORE_TEST="$ROOT/android/pika-release.test.jks"
CI_KEY_TMP=""
TMP_YAML=""
GH_REPO_TARGET="sledtools/pika"

# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

usage() {
  cat <<'EOF'
usage: ./scripts/init-release-secrets

One-shot release bootstrap:
  1. Generate fresh CI age key (ephemeral on local disk).
  2. Generate fresh Android keystore + random password.
  3. Encrypt repo secrets to:
     - YubiKey primary recipient
     - YubiKey backup recipient
     - CI recipient (from fresh key)
  4. Verify decrypt with YubiKey identity file (single-key test).
  5. Set GitHub Actions repo secrets:
     - AGE_SECRET_KEY (only)

Cleanup:
  - Removes plaintext keystores and CI private key temp file on exit.
  - Does not write secrets into /tmp.

Environment overrides:
  PIKA_AGE_IDENTITY_FILE  (tested key; defaults to yubikey-primary identity file, then falls back to ~/configs/yubikeys/keys.txt)
  PIKA_YUBIKEY_PRIMARY_RECIPIENT
  PIKA_YUBIKEY_BACKUP_RECIPIENT
  PIKA_CI_AGE_RECIPIENT
  PIKA_KEYSTORE_PASSWORD
  PIKA_ZAPSTORE_SIGN_WITH
EOF
}

cleanup() {
  rm -f "$KEYSTORE_PLAINTEXT" "$KEYSTORE_TEST"
  if [ -n "$CI_KEY_TMP" ]; then
    rm -f "$CI_KEY_TMP"
  fi
  if [ -n "$TMP_YAML" ]; then
    rm -f "$TMP_YAML"
  fi
}
trap cleanup EXIT INT TERM

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi
if [ "$#" -ne 0 ]; then
  usage >&2
  exit 2
fi

release_secret_need_cmd age
release_secret_need_cmd age-keygen
release_secret_need_cmd keytool
release_secret_need_cmd openssl
release_secret_need_cmd gh
release_secret_need_cmd grep
sops_secret_need_cmd sops

YUBIKEY_IDENTITY_FILE="$(release_secret_identity_file_for_init)"
release_secret_require_identity_file "$YUBIKEY_IDENTITY_FILE"

if ! gh auth status >/dev/null 2>&1; then
  echo "error: gh is not authenticated; run 'gh auth login' first" >&2
  exit 1
fi

mkdir -p "$ROOT/android" "$ROOT/secrets"
umask 077

echo "Generating fresh CI age key..."
CI_KEY_TMP="$(mktemp "$ROOT/secrets/.pika-ci-age.XXXXXX.key")"
age-keygen -o "$CI_KEY_TMP" >/dev/null
chmod 600 "$CI_KEY_TMP"

ci_recipient="$(age-keygen -y "$CI_KEY_TMP")"
ci_secret_key="$(grep '^AGE-SECRET-KEY-' "$CI_KEY_TMP" | head -n 1 || true)"
if [ -z "$ci_secret_key" ]; then
  echo "error: failed to read generated CI secret key" >&2
  exit 1
fi

release_secret_load_recipients "$ROOT" "$ci_recipient"
recipients=(
  "$RELEASE_SECRET_YUBIKEY_PRIMARY"
  "$RELEASE_SECRET_YUBIKEY_BACKUP"
  "$RELEASE_SECRET_CI_RECIPIENT"
)
recipients_csv="$(IFS=,; printf '%s' "${recipients[*]}")"

keystore_password="${PIKA_KEYSTORE_PASSWORD:-}"
if [ -z "$keystore_password" ]; then
  keystore_password="$(openssl rand -base64 48 | tr -d '\n')"
fi

echo "Generating release keystore..."
rm -f "$KEYSTORE_PLAINTEXT"
keytool -genkeypair -v \
  -keystore "$KEYSTORE_PLAINTEXT" \
  -alias pika \
  -keyalg RSA \
  -keysize 2048 \
  -validity 10000 \
  -dname "CN=Pika, O=Pika, L=Unknown, ST=Unknown, C=US" \
  -storepass "$keystore_password" \
  -keypass "$keystore_password" \
  >/dev/null
chmod 600 "$KEYSTORE_PLAINTEXT"

echo "Encrypting keystore to YubiKey primary + YubiKey backup + CI..."
sops_secret_encrypt_binary_file "$KEYSTORE_PLAINTEXT" "$KEYSTORE_ENCRYPTED" "$recipients_csv"

echo "Encrypting signing password to recipients..."
TMP_YAML="$(mktemp "$ROOT/secrets/.android-signing.XXXXXX.yaml")"
printf 'PIKA_KEYSTORE_PASSWORD: |-\n' >"$TMP_YAML"
while IFS= read -r line; do
  printf '  %s\n' "$line" >>"$TMP_YAML"
done <<<"$keystore_password"
sops_secret_encrypt_yaml_file "$TMP_YAML" "$PASSWORD_ENCRYPTED" "$recipients_csv"

if [ -n "${PIKA_ZAPSTORE_SIGN_WITH:-}" ]; then
  echo "Encrypting Zapstore signing env to recipients..."
  printf 'ZAPSTORE_SIGN_WITH: |-\n' >"$TMP_YAML"
  while IFS= read -r line; do
    printf '  %s\n' "$line" >>"$TMP_YAML"
  done <<<"$PIKA_ZAPSTORE_SIGN_WITH"
  sops_secret_encrypt_yaml_file "$TMP_YAML" "$ZAPSTORE_SIGNING_ENCRYPTED" "$recipients_csv"
fi

echo "Testing YubiKey decryption with $YUBIKEY_IDENTITY_FILE (touch/PIN may be required)..."
rm -f "$KEYSTORE_TEST"
SOPS_AGE_KEY_FILE="$YUBIKEY_IDENTITY_FILE" sops_secret_decrypt_binary "$KEYSTORE_ENCRYPTED" "$KEYSTORE_TEST"
chmod 600 "$KEYSTORE_TEST"

password_test="$(SOPS_AGE_KEY_FILE="$YUBIKEY_IDENTITY_FILE" sops_secret_read_key "$PASSWORD_ENCRYPTED" "PIKA_KEYSTORE_PASSWORD")"
if [ -z "$password_test" ]; then
  echo "error: failed to recover PIKA_KEYSTORE_PASSWORD from $PASSWORD_ENCRYPTED" >&2
  exit 1
fi
keytool -list -keystore "$KEYSTORE_TEST" -storepass "$password_test" >/dev/null
unset password_test
unset keystore_password

echo "Setting GitHub secrets (repo-scoped)..."
echo "  - deleting old AGE_SECRET_KEY / PIKA_KEYSTORE_PASSWORD (if present)"
gh secret delete AGE_SECRET_KEY --repo "$GH_REPO_TARGET" >/dev/null 2>&1 || true
gh secret delete PIKA_KEYSTORE_PASSWORD --repo "$GH_REPO_TARGET" >/dev/null 2>&1 || true
echo "  - setting fresh AGE_SECRET_KEY"
gh secret set AGE_SECRET_KEY --repo "$GH_REPO_TARGET" --body "$ci_secret_key" >/dev/null
unset ci_secret_key

echo "ok: wrote $KEYSTORE_ENCRYPTED"
echo "ok: wrote $PASSWORD_ENCRYPTED"
if [ -n "${PIKA_ZAPSTORE_SIGN_WITH:-}" ]; then
  echo "ok: wrote $ZAPSTORE_SIGNING_ENCRYPTED"
else
  echo "note: skipped $ZAPSTORE_SIGNING_ENCRYPTED (set PIKA_ZAPSTORE_SIGN_WITH to include it)"
fi
echo "ok: recipients:"
echo "  - $RELEASE_SECRET_YUBIKEY_PRIMARY"
echo "  - $RELEASE_SECRET_YUBIKEY_BACKUP"
echo "  - $RELEASE_SECRET_CI_RECIPIENT (CI)"
echo "ok: YubiKey decrypt test passed"
echo "note: backup recipient is included in encryption but was not separately tested"
echo "note: if the CI recipient changed, update secrets/.sops.yaml and run ./scripts/update-repo-secret-keys"
echo "ok: GitHub secrets updated for $GH_REPO_TARGET (AGE_SECRET_KEY)"
