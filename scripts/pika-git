#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_MAX_PRS="2"
DEFAULT_PORT="8787"
DEV_CONFIG_PATH="$ROOT/.tmp/pika-git.dev.toml"
DEV_DB_PATH="$ROOT/.tmp/pika-git.db"

# shellcheck source=scripts/lib/infra-env.sh
source "$ROOT/scripts/lib/infra-env.sh"

usage() {
  cat <<'EOF'
usage: ./scripts/pika-git [max-prs]

Run pika-git in local hosted-mode with cargo-watch.

This synthesizes a local dev config under .tmp/ and points the forge at the
repo's shared git dir so branch/forge pages can be exercised locally.
EOF
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: missing command: $1" >&2
    exit 1
  fi
}

write_dev_config() {
  local canonical_git_dir="${1:?canonical git dir is required}"
  local bind_port="${2:?bind port is required}"

  mkdir -p "$ROOT/.tmp"
  cat >"$DEV_CONFIG_PATH" <<EOF
repos = ["sledtools/pika"]

poll_interval_secs = 60
model = "claude-sonnet-4-5-20250929"
api_key_env = "ANTHROPIC_API_KEY"
github_token_env = "GITHUB_TOKEN"
merged_lookback_hours = 72
worker_concurrency = 2
retry_backoff_secs = 120
bind_address = "127.0.0.1"
bind_port = ${bind_port}

[forge_repo]
repo = "sledtools/pika"
canonical_git_dir = "$canonical_git_dir"
default_branch = "master"
mirror_remote = "github"
mirror_poll_interval_secs = 300
hook_url = "http://127.0.0.1:${bind_port}/git/webhook"
EOF
}

main() {
  local max_prs="${1:-$DEFAULT_MAX_PRS}"
  local bind_port="${PIKA_GIT_PORT:-${PIKA_NEWS_PORT:-$DEFAULT_PORT}}"

  if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    usage
    return 0
  fi
  if [ "$#" -gt 1 ]; then
    usage >&2
    return 2
  fi

  need_cmd cargo
  need_cmd gh
  need_cmd git

  cd "$ROOT"
  load_repo_env_override "$ROOT"
  export GITHUB_TOKEN="$(gh auth token)"

  local canonical_git_dir
  canonical_git_dir="$(git rev-parse --git-common-dir)"
  if [ "${canonical_git_dir#/}" = "$canonical_git_dir" ]; then
    canonical_git_dir="$ROOT/$canonical_git_dir"
  fi

  write_dev_config "$canonical_git_dir" "$bind_port"

  exec cargo watch \
    -w crates/pika-git \
    -x "run -p pika-git -- serve --config $DEV_CONFIG_PATH --db $DEV_DB_PATH --max-prs $max_prs"
}

main "$@"
