#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOPS_SIGNING_FILE="$ROOT/secrets/android-signing.sops.yaml"
AGE_SIGNING_FILE="$ROOT/secrets/android-signing.env.age"
# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

if [ -n "${PIKA_KEYSTORE_PASSWORD:-}" ]; then
  printf '%s\n' "$PIKA_KEYSTORE_PASSWORD"
  exit 0
fi

if [ -f "$SOPS_SIGNING_FILE" ]; then
  password="$(sops_secret_read_key "$SOPS_SIGNING_FILE" "PIKA_KEYSTORE_PASSWORD")"
else
  release_secret_require_file "$AGE_SIGNING_FILE" "encrypted signing env" "create it via ./scripts/init-release-secrets or migrate to secrets/android-signing.sops.yaml"
  password="$(release_secret_read_encrypted_env_value "$AGE_SIGNING_FILE" "PIKA_KEYSTORE_PASSWORD")"
fi

if [ -z "$password" ]; then
  echo "error: encrypted signing env is missing PIKA_KEYSTORE_PASSWORD" >&2
  exit 1
fi

printf '%s\n' "$password"
