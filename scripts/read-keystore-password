#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENCRYPTED_SIGNING_ENV="$ROOT/secrets/android-signing.env.age"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

if [ -n "${PIKA_KEYSTORE_PASSWORD:-}" ]; then
  printf '%s\n' "$PIKA_KEYSTORE_PASSWORD"
  exit 0
fi

release_secret_require_file "$ENCRYPTED_SIGNING_ENV" "encrypted signing env" "create it via ./scripts/init-release-secrets"

password="$(release_secret_read_encrypted_env_value "$ENCRYPTED_SIGNING_ENV" "PIKA_KEYSTORE_PASSWORD")"

if [ -z "$password" ]; then
  echo "error: encrypted signing env is missing PIKA_KEYSTORE_PASSWORD" >&2
  exit 1
fi

printf '%s\n' "$password"
