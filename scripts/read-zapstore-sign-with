#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENCRYPTED_SIGNING_ENV="$ROOT/secrets/zapstore-signing.env.age"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

if [ -n "${ZAPSTORE_SIGN_WITH:-}" ]; then
  printf '%s\n' "$ZAPSTORE_SIGN_WITH"
  exit 0
fi

release_secret_require_file "$ENCRYPTED_SIGNING_ENV" "encrypted Zapstore signing env" "create it via ./scripts/encrypt-zapstore-signing"

sign_with="$(release_secret_read_encrypted_env_value "$ENCRYPTED_SIGNING_ENV" "ZAPSTORE_SIGN_WITH")"

if [ -z "$sign_with" ]; then
  echo "error: encrypted signing env is missing ZAPSTORE_SIGN_WITH" >&2
  exit 1
fi

printf '%s\n' "$sign_with"
