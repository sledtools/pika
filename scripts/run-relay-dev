#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA_DIR="$ROOT/.pika-relay/data"
MEDIA_DIR="$ROOT/.pika-relay/media"
SERVICE_URL="http://localhost:3334"

usage() {
  cat <<'EOF'
usage: ./scripts/run-relay-dev

Run pika-relay with persistent local dev data under .pika-relay/.
EOF
}

main() {
  if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    usage
    return 0
  fi
  if [ "$#" -ne 0 ]; then
    usage >&2
    return 2
  fi

  mkdir -p "$DATA_DIR" "$MEDIA_DIR"
  cd "$ROOT/cmd/pika-relay"
  exec env \
    DATA_DIR="$DATA_DIR" \
    MEDIA_DIR="$MEDIA_DIR" \
    SERVICE_URL="$SERVICE_URL" \
    go run .
}

main "$@"
