#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CARGO_TOML="$ROOT/cli/Cargo.toml"
PACKAGE_JSON="$ROOT/pikachat-openclaw/openclaw/extensions/pikachat-openclaw/package.json"
CARGO_LOCK="$ROOT/Cargo.lock"

usage() {
  cat <<'EOF'
Usage: ./scripts/sync-pikachat-version [<version>]

Syncs the pikachat Rust binary and OpenClaw extension versions.

- With no argument, reads the version from the repo-root VERSION file.
- With an explicit argument, uses that version instead.

Updates:
- cli/Cargo.toml
- pikachat-openclaw/openclaw/extensions/pikachat-openclaw/package.json
- Cargo.lock (via `cargo check -p pikachat`)
EOF
}

if [ "$#" -gt 1 ]; then
  usage >&2
  exit 2
fi

if [ "$#" -eq 1 ]; then
  VERSION="$1"
else
  VERSION="$("$ROOT/scripts/version-read" --name)"
fi

if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "error: version must be x.y.z (got: $VERSION)" >&2
  exit 1
fi

CARGO_TOML_BAK="$(mktemp "${TMPDIR:-/tmp}/pikachat-cargo-toml.XXXXXX")"
PACKAGE_JSON_BAK="$(mktemp "${TMPDIR:-/tmp}/pikachat-package-json.XXXXXX")"
CARGO_LOCK_BAK="$(mktemp "${TMPDIR:-/tmp}/pikachat-cargo-lock.XXXXXX")"
success=0

cleanup() {
  if [ "$success" -ne 1 ]; then
    cp "$CARGO_TOML_BAK" "$CARGO_TOML"
    cp "$PACKAGE_JSON_BAK" "$PACKAGE_JSON"
    cp "$CARGO_LOCK_BAK" "$CARGO_LOCK"
  fi
  rm -f "$CARGO_TOML_BAK" "$PACKAGE_JSON_BAK" "$CARGO_LOCK_BAK"
}

trap cleanup EXIT

cp "$CARGO_TOML" "$CARGO_TOML_BAK"
cp "$PACKAGE_JSON" "$PACKAGE_JSON_BAK"
cp "$CARGO_LOCK" "$CARGO_LOCK_BAK"

awk -v version="$VERSION" '
  BEGIN {
    in_package = 0
    updated = 0
  }
  /^\[package\]$/ {
    in_package = 1
    print
    next
  }
  /^\[/ {
    in_package = 0
  }
  in_package && !updated && /^version = ".*"$/ {
    print "version = \"" version "\""
    updated = 1
    next
  }
  {
    print
  }
  END {
    if (!updated) {
      exit 1
    }
  }
' "$CARGO_TOML" > "$CARGO_TOML.tmp" || {
  rm -f "$CARGO_TOML.tmp"
  echo "error: failed to update package version in $CARGO_TOML" >&2
  exit 1
}
mv "$CARGO_TOML.tmp" "$CARGO_TOML"

node - "$PACKAGE_JSON" "$VERSION" <<'EOF'
const fs = require("fs");

const [pkgPath, version] = process.argv.slice(2);
const pkg = JSON.parse(fs.readFileSync(pkgPath, "utf8"));
pkg.version = version;
fs.writeFileSync(pkgPath, `${JSON.stringify(pkg, null, 2)}\n`);
EOF

cd "$ROOT"
cargo check -p pikachat --quiet

success=1
echo "ok: synced pikachat artifacts to version $VERSION"
