#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"

files=(
  "$ROOT/secrets/android-keystore.jks.sops"
  "$ROOT/secrets/android-signing.sops.yaml"
  "$ROOT/secrets/zapstore-signing.sops.yaml"
  "$ROOT/secrets/pikaci-apple.sops.yaml"
)

updated=0
for file in "${files[@]}"; do
  if [ ! -f "$file" ]; then
    continue
  fi

  echo "==> updating recipients for $file"
  sops_secret_updatekeys "$file"
  updated=1
done

if [ "$updated" -eq 0 ]; then
  echo "note: no repo sops files found under $ROOT/secrets"
fi
