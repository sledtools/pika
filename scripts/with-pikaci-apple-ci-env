#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: ./scripts/with-pikaci-apple-ci-env [--secret-set all|tailscale|ssh|none] <command> [args...]

Loads Apple mini CI public config and decrypted secrets into the current process
environment, masks secret values under GitHub Actions, then execs the requested
command. This keeps Apple secrets step-local instead of writing them to
GITHUB_ENV or GITHUB_OUTPUT.
EOF
}

secret_set="all"

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --secret-set)
      secret_set="${2:?missing value for --secret-set}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

if [[ "$#" -eq 0 ]]; then
  usage
  exit 2
fi

case "$secret_set" in
  all|tailscale|ssh|none)
    ;;
  *)
    echo "error: unsupported --secret-set value: $secret_set" >&2
    usage >&2
    exit 2
    ;;
esac

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PUBLIC_ENV_FILE="$ROOT/.github/pikaci-apple.env"
SOPS_SECRET_FILE="$ROOT/secrets/pikaci-apple.sops.yaml"
AGE_SECRET_FILE="$ROOT/secrets/pikaci-apple.env.age"
# shellcheck source=scripts/lib/sops-secrets.sh
source "$ROOT/scripts/lib/sops-secrets.sh"
# shellcheck source=scripts/lib/release-secrets.sh
source "$ROOT/scripts/lib/release-secrets.sh"

release_secret_require_file "$PUBLIC_ENV_FILE" "Apple mini public CI env" "commit .github/pikaci-apple.env"

tmp_secret_env="$(mktemp "${TMPDIR:-/tmp}/pikaci-apple-env.XXXXXX")"
cleanup() {
  rm -f "$tmp_secret_env"
}
trap cleanup EXIT INT TERM

# shellcheck disable=SC1090
source "$PUBLIC_ENV_FILE"

if [ -f "$SOPS_SECRET_FILE" ]; then
  {
    printf 'PIKACI_APPLE_TAILSCALE_AUTHKEY=%q\n' "$(sops_secret_read_key "$SOPS_SECRET_FILE" "PIKACI_APPLE_TAILSCALE_AUTHKEY")"
    printf 'PIKACI_APPLE_SSH_KEY=%q\n' "$(sops_secret_read_key "$SOPS_SECRET_FILE" "PIKACI_APPLE_SSH_KEY")"
  } >"$tmp_secret_env"
else
  release_secret_require_file "$AGE_SECRET_FILE" "encrypted Apple mini CI env" "create it via ./scripts/encrypt-pikaci-apple-secrets"
  release_secret_decrypt_to_file "$AGE_SECRET_FILE" "$tmp_secret_env"
fi

# shellcheck disable=SC1090
source "$tmp_secret_env"

require_value() {
  local key="$1"
  local value="$2"
  if [[ -z "$value" ]]; then
    echo "error: missing $key in Apple CI config" >&2
    exit 1
  fi
  if [[ "$value" == REPLACE_* ]]; then
    echo "error: $key still has placeholder value; update the Apple repo secret via ./scripts/encrypt-pikaci-apple-secrets or sops secrets/pikaci-apple.sops.yaml" >&2
    exit 1
  fi
}

mask_value() {
  local value="$1"
  if [[ -z "$value" || -z "${GITHUB_ACTIONS:-}" ]]; then
    return
  fi
  printf '::add-mask::%s\n' "$value"
}

mask_multiline_value() {
  local value="$1"
  if [[ -z "$value" || -z "${GITHUB_ACTIONS:-}" ]]; then
    return
  fi
  while IFS= read -r line; do
    [[ -n "$line" ]] && mask_value "$line"
  done <<<"$value"
}

require_value "PIKACI_APPLE_SSH_HOST" "${PIKACI_APPLE_SSH_HOST:-}"
require_value "PIKACI_APPLE_SSH_USER" "${PIKACI_APPLE_SSH_USER:-}"
require_value "PIKACI_APPLE_REMOTE_ROOT" "${PIKACI_APPLE_REMOTE_ROOT:-}"
require_value "PIKACI_APPLE_KEEP_RUNS" "${PIKACI_APPLE_KEEP_RUNS:-}"

if [[ "$secret_set" == "all" || "$secret_set" == "tailscale" ]]; then
  require_value "PIKACI_APPLE_TAILSCALE_AUTHKEY" "${PIKACI_APPLE_TAILSCALE_AUTHKEY:-}"
  if [[ "${PIKACI_APPLE_TAILSCALE_AUTHKEY:-}" != tskey-auth-* ]]; then
    echo "error: PIKACI_APPLE_TAILSCALE_AUTHKEY must be a tailscale auth key (expected prefix tskey-auth-)" >&2
    echo "hint: update the Apple repo secret using an auth key from the tailnet auth keys page" >&2
    exit 1
  fi
  mask_value "${PIKACI_APPLE_TAILSCALE_AUTHKEY:-}"
  export PIKACI_APPLE_TAILSCALE_AUTHKEY
fi

if [[ "$secret_set" == "all" || "$secret_set" == "ssh" ]]; then
  require_value "PIKACI_APPLE_SSH_KEY" "${PIKACI_APPLE_SSH_KEY:-}"
  mask_multiline_value "${PIKACI_APPLE_SSH_KEY:-}"
  export PIKACI_APPLE_SSH_KEY
fi

export PIKACI_APPLE_SSH_HOST
export PIKACI_APPLE_SSH_USER
export PIKACI_APPLE_REMOTE_ROOT
export PIKACI_APPLE_KEEP_RUNS
export PIKACI_APPLE_LOCK_TIMEOUT_SEC="${PIKACI_APPLE_LOCK_TIMEOUT_SEC:-0}"

exec "$@"
