#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cat >&2 <<'EOF'
warning: ./scripts/write-pikaci-apple-github-env is deprecated because writing Apple
CI secrets through GITHUB_ENV/GITHUB_OUTPUT is unsafe.
Use ./scripts/with-pikaci-apple-ci-env instead.
EOF

exec "$ROOT/scripts/with-pikaci-apple-ci-env" "$@"
