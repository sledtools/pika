#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [ "$#" -eq 0 ]; then
  exec cargo test -p pikahut --test integration_deterministic cli_smoke_local -- --ignored --nocapture
fi

if [ "$#" -eq 1 ] && [ "$1" = "--with-media" ]; then
  exec cargo test -p pikahut --test integration_deterministic cli_smoke_media_local -- --ignored --nocapture
fi

cat >&2 <<USAGE
usage:
  ./tools/cli-smoke
  ./tools/cli-smoke --with-media

note: this wrapper now dispatches Rust selectors only.
USAGE
exit 2
