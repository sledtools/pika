#!/usr/bin/env bash
set -euo pipefail

# Explain how to get the pinned iOS Simulator runtime installed.
# We intentionally do NOT auto-install by default because it can require
# Apple credentials and downloads many GB.

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

DEV_DIR="$("$ROOT/tools/xcode-dev-dir")"
export DEVELOPER_DIR="$DEV_DIR"

SIMCTL="$DEV_DIR/usr/bin/simctl"
target_runtime="$("$ROOT/tools/apple-host-asset" ios_runtime)"

ensure_mode=0
quiet_check=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --ensure)
      ensure_mode=1
      shift
      ;;
    --quiet-check)
      quiet_check=1
      shift
      ;;
    -h|--help)
      cat <<'EOF'
usage: ./tools/ios-runtime-doctor [--ensure] [--quiet-check]

Check or install the repo-pinned iOS Simulator runtime.
EOF
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

has_runtimes() {
  # `simctl list runtimes` prints a header line, then entries (or nothing).
  [ -n "$("$SIMCTL" list runtimes | sed -n '2,$p' | tr -d '[:space:]')" ]
}

has_target_runtime() {
  "$SIMCTL" list runtimes | grep -Fq "$target_runtime"
}

if has_runtimes && has_target_runtime; then
  if [[ "$quiet_check" -eq 0 ]]; then
    echo "ok: pinned iOS Simulator runtime is installed: $target_runtime"
    "$SIMCTL" list runtimes | sed -n '1,40p' || true
  fi
  exit 0
fi

XCODES_BIN="$(command -v xcodes 2>/dev/null || true)"
if [[ "$ensure_mode" -eq 1 ]]; then
  if [ -n "${XCODES_BIN:-}" ]; then
    "$XCODES_BIN" runtimes install "$target_runtime"
    if has_target_runtime; then
      echo "ok: installed pinned iOS Simulator runtime: $target_runtime"
      exit 0
    fi
  fi
  xcodebuild -downloadPlatform iOS
  if has_target_runtime; then
    echo "ok: installed pinned iOS Simulator runtime: $target_runtime"
    exit 0
  fi
  echo "error: failed to install pinned iOS Simulator runtime: $target_runtime" >&2
  exit 1
fi

if [[ "$quiet_check" -eq 1 ]]; then
  exit 1
fi

cat >&2 <<EOF
error: Pinned iOS Simulator runtime is not installed: ${target_runtime}

Pika can build the iOS simulator app, but it cannot boot a simulator without an iOS runtime.

Recommended (most reliable):
  1) Open Xcode
  2) Xcode -> Settings -> Platforms
  3) Download "${target_runtime}"

Optional (scriptable) if you have the \`xcodes\` tool installed:
  1) List runtimes:   xcodes runtimes
  2) Install one:     xcodes runtimes install "${target_runtime}"
  Notes:
  - This can require Apple ID auth (xcodes will prompt).
  - Downloads are large (many GB).

Alternative (advanced/offline):
  - If you already have a runtime image artifact, you can add it with:
      xcrun simctl runtime add <path-to-runtime.dmg-or-pkg>

After installing a runtime, retry:
  just run-ios
  just ios-ui-test
EOF

exit 1
