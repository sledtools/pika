#!/usr/bin/env bash
set -euo pipefail

# Run a command with a working Xcode toolchain env even inside Nix/direnv shells:
# - resolves the pinned Xcode Developer dir
# - unsets common Nix compiler env vars that break xcodebuild
# - strips obvious secrets and bulky Nix derivation vars that Xcode would echo
#   into build logs via scheme pre-actions

TOOLS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEV_DIR="$("$TOOLS_DIR/xcode-dev-dir")"
XCODE_BIN="$DEV_DIR/usr/bin"
XCODE_TOOLCHAIN_BIN="$DEV_DIR/Toolchains/XcodeDefault.xctoolchain/usr/bin"

unset_args=(
  -u LD
  -u CC
  -u CXX
  -u AR
  -u RANLIB
  -u SDKROOT
  -u MACOSX_DEPLOYMENT_TARGET
  -u buildInputs
  -u propagatedBuildInputs
  -u nativeBuildInputs
  -u propagatedNativeBuildInputs
  -u depsBuildBuild
  -u depsBuildBuildPropagated
  -u depsBuildTarget
  -u depsBuildTargetPropagated
  -u depsHostHost
  -u depsHostHostPropagated
  -u depsTargetTarget
  -u depsTargetTargetPropagated
  -u buildPhase
  -u shellHook
  -u out
  -u outputs
  -u phases
  -u stdenv
)

while IFS='=' read -r name _; do
  case "$name" in
    *_API_KEY|*_TOKEN|*_SECRET|*_PASSWORD)
      unset_args+=(-u "$name")
      ;;
    AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_SESSION_TOKEN|GH_TOKEN|GITHUB_TOKEN)
      unset_args+=(-u "$name")
      ;;
  esac
done < <(env)

path_prefixes=("$XCODE_BIN")
if [ -d "$XCODE_TOOLCHAIN_BIN" ]; then
  path_prefixes+=("$XCODE_TOOLCHAIN_BIN")
fi
path_prefixes+=("/usr/bin")

PATH_PREFIX="$(IFS=:; echo "${path_prefixes[*]}")"
if [ -n "${PATH:-}" ]; then
  PATH_PREFIX="$PATH_PREFIX:$PATH"
fi

exec env "${unset_args[@]}" DEVELOPER_DIR="$DEV_DIR" PATH="$PATH_PREFIX" "$@"
