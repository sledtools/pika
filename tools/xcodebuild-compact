#!/usr/bin/env python3
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
LOG_DIR = Path(os.environ.get("PIKA_XCODEBUILD_LOG_DIR", ROOT / "ios" / "build-logs"))
DIAG_RE = re.compile(r"^.+:\d+:\d+: (?P<level>fatal error|error|warning|note): ")


def print_err(message: str) -> None:
    sys.stderr.write(message)
    if not message.endswith("\n"):
        sys.stderr.write("\n")


def render_failure(log_path: Path) -> None:
    try:
        lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError as exc:
        print_err(f"error: failed to read xcodebuild log: {exc}")
        return

    diag_indexes = [idx for idx, line in enumerate(lines) if DIAG_RE.match(line)]
    error_indexes = [
        idx for idx in diag_indexes
        if DIAG_RE.match(lines[idx]) and DIAG_RE.match(lines[idx]).group("level") in {"error", "fatal error"}
    ]

    if not error_indexes:
        print_err("error: xcodebuild failed, but no Swift compiler diagnostics were extracted")
        print_err(f"log: {log_path}")
        return

    print_err("xcodebuild failed. Extracted diagnostics:")
    printed = set()
    for error_idx in error_indexes:
        block_lines = [lines[error_idx]]
        cursor = error_idx + 1
        while cursor < len(lines):
            next_line = lines[cursor]
            if DIAG_RE.match(next_line):
                if ": note: " not in next_line:
                    break
                block_lines.append(next_line)
                cursor += 1
                while cursor < len(lines) and lines[cursor].startswith(" "):
                    block_lines.append(lines[cursor])
                    cursor += 1
                continue
            if not next_line.startswith(" "):
                break
            block_lines.append(next_line)
            cursor += 1

        block = tuple(block_lines)
        if block in printed:
            continue
        printed.add(block)
        for line in block:
            print_err(line)
        print_err("")

    warning_count = sum(1 for idx in diag_indexes if ": warning: " in lines[idx])
    if warning_count:
        print_err(f"warning count in log: {warning_count}")
    print_err(f"log: {log_path}")


def main() -> int:
    verbose = os.environ.get("PIKA_XCODEBUILD_VERBOSE", "0") == "1"
    show_timing_summary = os.environ.get("PIKA_XCODEBUILD_SHOW_TIMING_SUMMARY", "0") == "1"
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print_err(f"error: failed to create xcodebuild log directory {LOG_DIR}: {exc}")
        return 2
    log_path = LOG_DIR / f"xcodebuild-{timestamp}.log"

    cmd = [str(ROOT / "tools" / "xcode-run"), "xcodebuild"]
    args = sys.argv[1:]
    if not verbose and not show_timing_summary and "-quiet" not in args:
        args = ["-quiet", *args]
    if show_timing_summary and "-showBuildTimingSummary" not in args:
        args = [*args, "-showBuildTimingSummary"]
    cmd.extend(args)

    print_err(f"xcodebuild: writing full log to {log_path}")
    try:
        proc = subprocess.run(
            cmd,
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
    except OSError as exc:
        print_err(f"error: failed to launch xcodebuild: {exc}")
        return 2

    try:
        log_path.write_text(proc.stdout or "", encoding="utf-8")
    except OSError as exc:
        print_err(f"error: failed to write xcodebuild log {log_path}: {exc}")
        return 2

    if proc.returncode == 0:
        warning_count = len(re.findall(r"^.+:\d+:\d+: warning: ", proc.stdout or "", flags=re.MULTILINE))
        if warning_count:
            print_err(f"xcodebuild: succeeded with {warning_count} warnings")
        else:
            print_err("xcodebuild: succeeded")
        print_err(f"log: {log_path}")
        return 0

    render_failure(log_path)
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
